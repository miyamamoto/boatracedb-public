# BoatRace Local Predictor optional settings
#
# The default installation works without copying this file.
# Copy to `.env` only when you want to override local paths.

# Where the local DuckDB file is stored.
BOATRACE_DB_PATH=data/boatrace_pipeline.duckdb

# Where trained local model files are stored.
BOATRACE_MODEL_DIR=models

# Where prediction JSON/Markdown and PDF outputs are written.
BOATRACE_OUTPUT_DIR=output

# Default bootstrap settings.
BOATRACE_TRAINING_DAYS=90
BOATRACE_RETRAIN_INTERVAL_DAYS=7
